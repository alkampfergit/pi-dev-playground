{
  "providers": {
    "azure-openai": {
      "baseUrl": "https://alkampferaiok-resource.services.ai.azure.com/openai/v1",
      "api": "openai-completions",
      "apiKey": "$AZURE_PI_TEST_API_KEY",
      "headers": {
        "api-key": "$AZURE_PI_TEST_API_KEY"
      },
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "cohere-command-a",
          "name": "cohere-command-a (Azure Foundry)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 256000,
          "maxTokens": 8192,
          "cost": {
            "input": 0,
            "output": 0,
            "cacheRead": 0,
            "cacheWrite": 0
          }
        }
      ]
    }
  }
}
